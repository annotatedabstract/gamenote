# Populated runtime config lives in %APPDATA%\gamenote, but never commit one if present
config.json

# Local editor/agent tooling config (personal, not for the repo)
.claude/settings.local.json

# Personal OBS workflow script (machine-specific paths; the generic trimmed
# version lives in integrations/obs/gamenote-obs.lua)
make_postprocess_bat.lua

# Logs
*.log

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# PyInstaller build artifacts
build/
dist/
*.spec.bak

# Build identity stamped by packaging/build.sh (bundled into the frozen app)
build_info.json

# Build-local model cache (downloaded by build.sh, bundled into dist; too large for git)
packaging/model_cache/

# Installer output (built by build-installer.sh)
packaging/installer_output/
