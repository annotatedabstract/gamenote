{
  "version": 1,
  "global": {
    "model_size": "small.en",
    "device": "auto",
    "beam_size": 1,
    "input_device": null,
    "sample_rate": 16000,
    "frame_ms": 30,
    "silence_threshold": 0.02,
    "silence_seconds": 1.5,
    "start_grace_seconds": 3.0,
    "min_seconds": 0.4,
    "max_seconds": 60.0,
    "language": "en",
    "overlay": { "enabled": true, "hide_ms": 2500 },
    "launch_sound": true,
    "launch_sound_file": "",
    "hotkey_beep_file": "",
    "auto_update": true,
    "update_channel": "stable",
    "context": { "value": "", "source": "manual", "file_path": "" },
    "log_level": "INFO"
  },
  "profiles": [
    {
      "id": "editing",
      "name": "Editing notes",
      "hotkey": "alt+f1",
      "dest_root": "C:\\Users\\you\\Documents\\gamenote",
      "path_template": "{context}_notes.md",
      "line_format": { "timestamp_format": "%Y-%m-%d %H:%M:%S", "prefix": "" },
      "use_session_headers": true,
      "clip_from_file": false,
      "clip_file": "",
      "hotkey_beep": true,
      "capture_mode": "vad"
    },
    {
      "id": "bugs",
      "name": "Bugs",
      "hotkey": "alt+f2",
      "dest_root": "C:\\Users\\you\\Documents\\gamenote",
      "path_template": "bugs.md",
      "line_format": { "timestamp_format": "%Y-%m-%d %H:%M:%S", "prefix": "[bug] " },
      "use_session_headers": false,
      "clip_from_file": false,
      "clip_file": "",
      "hotkey_beep": true,
      "capture_mode": "vad"
    },
    {
      "id": "daily",
      "name": "Daily log",
      "hotkey": "alt+f3",
      "dest_root": "C:\\Users\\you\\Documents\\gamenote",
      "path_template": "{date}_log.md",
      "line_format": { "timestamp_format": "%H:%M:%S", "prefix": "" },
      "use_session_headers": false,
      "clip_from_file": false,
      "clip_file": "",
      "hotkey_beep": true,
      "capture_mode": "vad"
    }
  ]
